---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalURL?: string;
  ogImage?: string;
  schema?: string;
}

const {
  title,
  description,
  canonicalURL = Astro.url.href,
  ogImage = '/og-default.png',
  schema,
} = Astro.props;

const siteName = 'TitanBTP';
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="fr_FR" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Schema.org -->
    {schema && <script type="application/ld+json" set:html={schema} />}

    <!-- Google tag (gtag.js) — chargé uniquement si consentement cookies -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      window.gtag = gtag;
      (function() {
        var c = localStorage.getItem('titanbtp_cookie_consent');
        if (c === 'accepted') {
          var s = document.createElement('script');
          s.async = true;
          s.src = 'https://www.googletagmanager.com/gtag/js?id=G-EC773FJK08';
          s.onload = function() {
            gtag('js', new Date());
            gtag('config', 'G-EC773FJK08');
          };
          document.head.appendChild(s);
        }
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <Navbar />
    <main class="flex-1 relative z-10">
      <slot />
    </main>
    <Footer />
    <CookieBanner />
    <script is:inline>
      document.body.addEventListener('click', function (e) {
        var el = e.target.closest('[data-ga-event]');
        if (el && typeof gtag === 'function') {
          gtag('event', el.getAttribute('data-ga-event'));
        }
      });
    </script>
    <script>
      (function () {
        const els = document.querySelectorAll('.animate-on-scroll');
        if (!els.length) return;
        const observer = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
              }
            });
          },
          { rootMargin: '0px 0px -8% 0px', threshold: 0 }
        );
        els.forEach(function (el) { observer.observe(el); });
      })();
    </script>
  </body>
</html>
