---
const stats = [
  { value: 'Devis & factures', label: 'Tout-en-un' },
  { value: 'Planning & CRM', label: 'Centralisé' },
  { value: 'Estimation IA', label: 'En quelques secondes' },
  { value: 'Support', label: 'Réactif' },
];
---

<section class="animate-on-scroll py-12 lg:py-16 border-y border-white/5 bg-surface-light/20 relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-r from-primary/5 via-transparent to-cta/5 pointer-events-none" aria-hidden="true"></div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
      {
        stats.map((stat) => (
          <div class="text-center">
            <p class="text-2xl sm:text-3xl font-bold text-white font-heading">{stat.value}</p>
            <p class="mt-1 text-sm text-gray-400">{stat.label}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
