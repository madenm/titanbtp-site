---
const consentKey = 'titanbtp_cookie_consent';
const gaId = 'G-EC773FJK08';
---

<div
  id="cookie-banner"
  class="cookie-banner fixed bottom-0 left-0 right-0 z-[100] p-4 sm:p-5 border-t border-white/10 bg-surface-light/98 backdrop-blur-sm shadow-[0_-4px_24px_rgba(0,0,0,0.2)] hidden"
  role="dialog"
  aria-label="Choix des cookies"
>
  <div class="max-w-4xl mx-auto flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <p class="text-sm text-gray-300 leading-relaxed">
      Nous utilisons des cookies pour analyser le trafic de notre site et améliorer votre expérience.
      Vos données ne sont jamais vendues.
    </p>
    <div class="flex items-center gap-3 shrink-0">
      <button
        type="button"
        id="cookie-refuse"
        class="px-4 py-2.5 text-sm font-medium text-gray-400 hover:text-white border border-white/15 rounded-lg hover:bg-white/5 transition-colors"
      >
        Refuser
      </button>
      <button
        type="button"
        id="cookie-accept"
        class="px-5 py-2.5 text-sm font-semibold bg-cta hover:bg-cta-dark text-gray-900 rounded-lg transition-colors hover:shadow-lg hover:shadow-cta/20"
      >
        Accepter
      </button>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    var consentKey = 'titanbtp_cookie_consent';
    var gaId = 'G-EC773FJK08';

    function loadGA4() {
      if (typeof gtag !== 'function') return;
      var s = document.createElement('script');
      s.async = true;
      s.src = 'https://www.googletagmanager.com/gtag/js?id=' + gaId;
      s.onload = function () {
        gtag('js', new Date());
        gtag('config', gaId);
      };
      document.head.appendChild(s);
    }

    function showBanner() {
      var el = document.getElementById('cookie-banner');
      if (el) el.classList.remove('hidden');
    }

    function hideBanner() {
      var el = document.getElementById('cookie-banner');
      if (el) el.classList.add('hidden');
    }

    var consent = localStorage.getItem(consentKey);
    if (consent !== 'accepted' && consent !== 'refused') {
      showBanner();
    }

    document.getElementById('cookie-accept')?.addEventListener('click', function () {
      localStorage.setItem(consentKey, 'accepted');
      loadGA4();
      hideBanner();
    });

    document.getElementById('cookie-refuse')?.addEventListener('click', function () {
      localStorage.setItem(consentKey, 'refused');
      hideBanner();
    });
  })();
</script>
