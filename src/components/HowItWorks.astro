---
const steps = [
  {
    number: '01',
    title: 'Vous recevez une réponse à votre demande',
    description: 'Pour mieux comprendre vos besoins et répondre à vos questions. Réservez un créneau ou écrivez-nous — sans engagement.',
    icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>`,
  },
  {
    number: '02',
    title: 'Vous bénéficiez d\'une démo 100 % personnalisée',
    description: 'Pour vous présenter TitanBTP et les offres Solo / Pro adaptées à votre activité.',
    icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>`,
  },
  {
    number: '03',
    title: 'Vous êtes accompagné dès le 1er jour',
    description: 'Mise en place, prise en main et formation pour utiliser TitanBTP au quotidien.',
    icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" /></svg>`,
  },
];
---

<section class="animate-on-scroll py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <span class="text-sm font-semibold text-primary-light uppercase tracking-wider">Parcours</span>
      <h2 class="mt-3 text-3xl sm:text-4xl font-bold text-white">
        Comment ça se passe ?
      </h2>
      <p class="mt-4 text-gray-400 text-lg max-w-2xl mx-auto">
        Une réponse rapide, une démo personnalisée, un accompagnement dès le premier jour.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12">
      {
        steps.map((step, i) => (
          <div class="relative text-center">
            {/* Connector line */}
            {i < steps.length - 1 && (
              <div class="hidden md:block absolute top-10 left-[60%] w-[80%] h-px bg-gradient-to-r from-primary/40 to-transparent"></div>
            )}
            <div class="inline-flex items-center justify-center w-20 h-20 rounded-2xl bg-gradient-to-br from-primary/20 to-primary/5 border border-primary/20 text-primary-light mb-6">
              <Fragment set:html={step.icon} />
            </div>
            <div class="text-xs font-bold text-primary/60 uppercase tracking-widest mb-2">Étape {step.number}</div>
            <h3 class="text-xl font-semibold text-white mb-3">{step.title}</h3>
            <p class="text-gray-400 leading-relaxed">{step.description}</p>
          </div>
        ))
      }
    </div>

    <div class="text-center mt-14">
      <a
        href="https://calendly.com/madenmustafa/new-meeting"
        target="_blank"
        rel="noopener noreferrer"
        data-ga-event="book_demo"
        class="inline-flex items-center gap-2 bg-cta hover:bg-cta-dark text-gray-900 font-semibold rounded-xl px-8 py-3.5 text-base transition-all hover:shadow-lg hover:shadow-cta/25"
      >
        Réserver votre démo personnalisée
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
      </a>
    </div>
  </div>
</section>
